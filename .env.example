# PakSentinel Configuration

# Database Settings
DATABASE_URL=postgresql://paksential:paksential_secure_pwd@localhost:5432/paksential_db
MONGO_URI=mongodb://paksential:paksential_secure_pwd@localhost:27017/paksential_db

# MinIO Settings
MINIO_ENDPOINT=http://localhost:9000
MINIO_ACCESS_KEY=paksential
MINIO_SECRET_KEY=paksential_secure_pwd
MINIO_BUCKET=paksential-data

# MLFlow Settings
MLFLOW_TRACKING_URI=http://localhost:5000
MLFLOW_EXPERIMENT_NAME=PakSentinel

# API Settings
API_HOST=0.0.0.0
API_PORT=8000
API_WORKERS=4
API_RELOAD=true

# Data Settings
DATA_DIR=./data
MODELS_DIR=./models
OUTPUT_DIR=./output

# Logging
LOG_LEVEL=INFO
LOG_FORMAT=json

# Feature Engineering
MAX_FEATURES=5000
MIN_TOKEN_LENGTH=1
REMOVE_STOPWORDS=true

# Model Settings
NB_ALPHA=1.0
LR_REGULARIZATION=l2
LR_C=1.0

# Processing
BATCH_SIZE=32
CHUNK_SIZE=1000

# Rate Limiting
CLASSIFY_RATE_LIMIT=100/minute
BATCH_RATE_LIMIT=10/minute
HEALTH_RATE_LIMIT=100/minute

# Performance
CLASSIFY_MAX_TIME_MS=100
BATCH_MAX_TIME_MS=500
PREPROCESS_MAX_TIME_MS=1000

# Pakistan Scraper
DAWN_FEED_URL=https://www.dawn.com/feeds/home
GEO_FEED_URL=https://www.geo.tv/rss/1/1
ARY_FEED_URL=https://arynews.tv/feed/
TWITTER_BEARER_TOKEN=AAAAAAAAAAAAAAAAAAAAAN009QEAAAAAG4BZVbBSh1PsxqzFrcMBhGeW5%2FY%3DbdRZy4IYjkvcFmjojqmDeSZWgi4SNNWMMftAqzIQqLD20ozIyh
TWITTER_FAKE_QUERIES="miracle cure" Pakistan lang:en -is:retweet||"viral claim" Pakistan lang:en -is:retweet||"unverified" Pakistan politics lang:en -is:retweet
TWITTER_SATIRE_QUERIES="satire" Pakistan politics lang:en -is:retweet||"parody" Pakistan government lang:en -is:retweet
TWITTER_SATIRE_HANDLES=Dawn_News,GeoNews_English,ARYNEWSOFFICIAL
